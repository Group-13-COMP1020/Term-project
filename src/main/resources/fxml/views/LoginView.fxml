<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vinrecipe.controller.LoginController"
      styleClass="login-root-split"
      prefWidth="1000" prefHeight="600">

    <!-- LEFT SIDE: Culinary Banner -->
    <VBox styleClass="login-banner" HBox.hgrow="ALWAYS" alignment="BOTTOM_LEFT" spacing="12">
        <padding><Insets top="48" bottom="48" left="48" right="48"/></padding>
        <VBox spacing="6" styleClass="banner-overlay">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="Cook together," styleClass="banner-title"/>
            <Label text="live better" styleClass="banner-title-highlight"/>
            <Label text="Join your dorm room and start managing groceries and meals efficiently."
                   styleClass="banner-subtitle" wrapText="true" maxWidth="380"/>
        </VBox>
    </VBox>

    <!-- RIGHT SIDE: Authentication Form -->
    <ScrollPane fitToWidth="true" styleClass="login-form-container" prefWidth="480"
                style="-fx-background-color: #FFFDF9; -fx-background: #FFFDF9; -fx-border-color: transparent;">
        <VBox alignment="CENTER" spacing="16" maxWidth="360"
              style="-fx-padding: 32 48 32 48;">

            <!-- Logo & Brand Header -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 0;">
                <ImageView fitHeight="36" fitWidth="36" preserveRatio="true">
                    <image>
                        <Image url="/images/logo.png"/>
                    </image>
                </ImageView>
                <Label text="VinRECIPE" style="-fx-font-family: 'Georgia', serif; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
            </HBox>

            <!-- Header labels -->
            <VBox spacing="4" alignment="CENTER_LEFT" styleClass="welcome-header">
                <Label fx:id="welcomeTitle" text="Welcome Back!" styleClass="form-welcome-title"/>
                <Label fx:id="welcomeSubtitle" text="Please enter your details to sign in." styleClass="form-welcome-subtitle"/>
            </VBox>

            <!-- ===== LOGIN FIELDS GROUP ===== -->
            <VBox fx:id="loginFieldsBox" spacing="14" alignment="CENTER_LEFT">
                <!-- Username -->
                <VBox spacing="6">
                    <Label text="Username" styleClass="form-label"/>
                    <HBox styleClass="input-box-container" alignment="CENTER_LEFT">
                        <padding><Insets left="12" right="12"/></padding>
                        <TextField fx:id="usernameField" promptText="Enter your username" styleClass="form-field-embedded" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="Password" styleClass="form-label"/>
                    <HBox styleClass="input-box-container" alignment="CENTER_LEFT">
                        <padding><Insets left="12" right="12"/></padding>
                        <PasswordField fx:id="passwordField" promptText="••••••••••••" styleClass="form-field-embedded" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ===== REGISTER-ONLY FIELDS GROUP ===== -->
            <VBox fx:id="registerFieldsBox" spacing="14" alignment="CENTER_LEFT" managed="false" visible="false">
            <!-- Role Selector -->
                <VBox spacing="8">
                    <Label text="Account Type" styleClass="form-label"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ToggleButton fx:id="roleLeaderBtn" text="Room Leader" onAction="#handleRoleToggle"
                                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8 16; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A5568; -fx-cursor: hand;"/>
                        <ToggleButton fx:id="roleStudentBtn" text="Join a Room" onAction="#handleRoleToggle"
                                      style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8 16; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A5568; -fx-cursor: hand;"/>
                    </HBox>
                    <Label text="Leaders create a room. Members join with a code." style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                </VBox>

                <!-- Room Name field (shown for both leader and student) -->
                <VBox fx:id="roomNameBox" spacing="6" managed="false" visible="false">
                    <Label text="Room Name" styleClass="form-label"/>
                    <HBox styleClass="input-box-container" alignment="CENTER_LEFT">
                        <padding><Insets left="12" right="12"/></padding>
                        <TextField fx:id="roomNameField" promptText="e.g. VinUni Dorm A-101" styleClass="form-field-embedded" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Access Code field (shown for student joining only) -->
                <VBox fx:id="accessCodeBox" spacing="6" managed="false" visible="false">
                    <Label text="Access Code" styleClass="form-label"/>
                    <HBox styleClass="input-box-container" alignment="CENTER_LEFT">
                        <padding><Insets left="12" right="12"/></padding>
                        <TextField fx:id="accessCodeField" promptText="6-char code from your leader" styleClass="form-field-embedded" HBox.hgrow="ALWAYS"
                                   style="-fx-font-family: 'Courier New', monospace; -fx-letter-spacing: 4;"/>
                    </HBox>
                    <Label text="Ask your room leader for the access code." style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                </VBox>
            </VBox>

            <!-- Status Message -->
            <Label fx:id="statusLabel" wrapText="true" maxWidth="Infinity" alignment="CENTER" styleClass="status-label"/>

            <!-- Action Buttons -->
            <StackPane maxWidth="Infinity">
                <Button fx:id="loginBtn" text="Sign In →" onAction="#handleLogin" styleClass="btn-primary-coral" maxWidth="Infinity" prefHeight="44"/>
                <Button fx:id="registerBtn" text="Create Account" onAction="#handleRegister" styleClass="btn-primary-coral" maxWidth="Infinity" prefHeight="44" managed="false" visible="false"/>
            </StackPane>

            <!-- Toggle link -->
            <HBox alignment="CENTER" spacing="4" maxWidth="Infinity" style="-fx-padding: 4 0 0 0;">
                <Label fx:id="toggleLabel" text="Don't have an account? Sign up" styleClass="toggle-link-coral" onMouseClicked="#toggleMode"/>
            </HBox>

        </VBox>
    </ScrollPane>

</HBox>
