<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vinrecipe.controller.RoomController"
      styleClass="view-root" spacing="20"
      style="-fx-background-color: #FAFAFA;">

    <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

    <!-- Header Row -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="roomNameLabel" text="VinUni Dorm A-101" styleClass="page-title" style="-fx-font-family: 'Segoe UI', sans-serif; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
            <Label fx:id="roomSubtitleLabel" text="VinUni sharing panel. Cook together, live better." styleClass="page-subtitle" style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D;"/>
        </VBox>
    </HBox>

    <Separator style="-fx-opacity: 0.4;"/>

    <!-- Main Workspace HBox -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        
        <!-- LEFT PANEL: Members List & Stats -->
        <VBox spacing="16" prefWidth="320" minWidth="320" maxWidth="320">
            
            <!-- Room Members Card -->
            <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16px; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 10, 0, 0, 2);">
                <Label text="Room Members" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2D3748;"/>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-max-height: 220;">
                    <VBox fx:id="membersBox" spacing="8" style="-fx-background-color: transparent;"/>
                </ScrollPane>
            </VBox>
            
            <!-- Room Statistics Card -->
            <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16px; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 10, 0, 0, 2);">
                <Label text="Room Stats" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2D3748;"/>
                
                <GridPane hgap="12" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    
                    <VBox spacing="4" style="-fx-background-color: #FAFAFA; -fx-background-radius: 8px; -fx-padding: 8; -fx-alignment: center;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label fx:id="statMembersCount" text="5" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E76F51;"/>
                        <Label text="Dormmates" style="-fx-font-size: 11px; -fx-text-fill: #718096;"/>
                    </VBox>
                    
                    <VBox spacing="4" style="-fx-background-color: #FAFAFA; -fx-background-radius: 8px; -fx-padding: 8; -fx-alignment: center;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label fx:id="statRecipesShared" text="8" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E76F51;"/>
                        <Label text="Recipes Shared" style="-fx-font-size: 11px; -fx-text-fill: #718096;"/>
                    </VBox>
                </GridPane>
            </VBox>
            
        </VBox>
        
        <!-- RIGHT PANEL: Announcement Board & shared Chores -->
        <VBox spacing="20" HBox.hgrow="ALWAYS">
            
            <!-- Dorm Announcements Board -->
            <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16px; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                <Label text="Dorm Announcement Board" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2D3748;"/>
                
                <!-- Quick Post announcement row -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="announcementInput" promptText="Post a cooking notice or announcement to your room..." HBox.hgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                    <Button text="Post 📣" onAction="#handlePostAnnouncement" style="-fx-background-color: #E76F51; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
                
                <Separator style="-fx-opacity: 0.3;"/>
                
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="announcementList" spacing="8" style="-fx-background-color: transparent; -fx-padding: 2 2 2 2;"/>
                </ScrollPane>
            </VBox>
            
            <!-- Room Cooking Plan & Grocery Summary -->
            <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16px; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                <Label text="Room Cooking Plan &amp; Groceries Summary" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2D3748;"/>
                
                <Label text="Selected Recipes for this Room:" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #E76F51;"/>
                <Label fx:id="recipesSummaryLabel" text="No recipes selected. Go to 'Shopping Lists' to select!" style="-fx-font-size: 13px; -fx-text-fill: #4A5568; -fx-wrap-text: true;"/>
                
                <Separator style="-fx-opacity: 0.3;"/>
                
                <Label text="Consolidated Ingredients to Buy:" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #E76F51;"/>
                <ListView fx:id="roomGroceriesListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-padding: 0;"/>
            </VBox>
            
        </VBox>
        
    </HBox>

</VBox>
